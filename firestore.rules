rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives & Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.keys().hasAny(['email']) && request.auth.token.email != null && request.auth.token.email.lower() == 'bruce@mcpher.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isUserEmail(email) {
      return email != null && 
             request.auth.token != null && 
             request.auth.token.keys().hasAny(['email']) && 
             request.auth.token.email != null && 
             email.lower() == request.auth.token.email.lower();
    }

    // Validation for Contributors (Entity-level validation helper)
    function isValidContributor(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.role is string && data.role.size() <= 100 &&
             data.bio is string && data.bio.size() <= 2000 &&
             (data.skills is list) &&
             (!data.keys().hasAny(['github']) || data.github == null || data.github is string) &&
             (!data.keys().hasAny(['linkedin']) || data.linkedin == null || data.linkedin is string) &&
             (!data.keys().hasAny(['twitter']) || data.twitter == null || data.twitter is string) &&
             (!data.keys().hasAny(['website']) || data.website == null || data.website is string) &&
             (!data.keys().hasAny(['company']) || data.company == null || data.company is string) &&
             (!data.keys().hasAny(['phone']) || data.phone == null || data.phone is string) &&
             (!data.keys().hasAny(['slideNotes']) || data.slideNotes == null || data.slideNotes is string) &&
             (data.status == 'pending' || data.status == 'approved') &&
             (!data.keys().hasAny(['systemRole']) || data.systemRole == null || data.systemRole == 'contributor' || data.systemRole == 'admin') &&
             (!data.keys().hasAny(['slideIndex']) || data.slideIndex is int) &&
             (!data.keys().hasAny(['userId']) || data.userId == null || data.userId is string) &&
             (!data.keys().hasAny(['avatarUrl']) || data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 150000)) &&
             (!data.keys().hasAny(['hidden']) || data.hidden is bool) &&
             (!data.keys().hasAny(['flagged']) || data.flagged is bool) &&
             (!data.keys().hasAny(['flagCount']) || data.flagCount is int) &&
             (!data.keys().hasAny(['flaggedReasons']) || data.flaggedReasons is list) &&
             (!data.keys().hasAny(['shareEmail']) || data.shareEmail is bool) &&
             (!data.keys().hasAny(['images']) || (data.images is list && data.images.size() <= 8)) &&
             (!data.keys().hasAny(['badges']) || (data.badges is list && data.badges.size() <= 10)) &&
             (!data.keys().hasAny(['additionalLinks']) || (data.additionalLinks is list && data.additionalLinks.size() <= 20)) &&
             (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp) &&
             (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp);
    }

    // Validation for Messages (Entity-level validation helper)
    function isValidMessage(data) {
      return data.contributorId is string && data.contributorId.size() <= 128 &&
             data.contributorEmail is string && data.contributorEmail.size() <= 150 &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() <= 100 &&
             data.senderEmail is string && data.senderEmail.size() > 0 && data.senderEmail.size() <= 150 &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 5000 &&
             data.read is bool &&
             (!data.keys().hasAny(['contributorUserId']) || data.contributorUserId == null || data.contributorUserId is string);
    }

    // Contributors Collection
    match /contributors/{contributorId} {
      allow read: if true; // Public access to directories

      allow create: if isSignedIn() && isValidId(contributorId) && isValidContributor(incoming()) && (
        isAdmin() || (
          // Normal authenticated user owns this and it created as pending
          incoming().status == 'pending' &&
          incoming().userId == request.auth.uid &&
          incoming().createdAt == request.time &&
          incoming().updatedAt == request.time
        )
      );

      allow update: if isSignedIn() && isValidId(contributorId) && isValidContributor(incoming()) && (
        isAdmin() || (
          // Contributor can edit their own profile
          (
            (
              (existing().keys().hasAny(['userId']) && existing().userId == request.auth.uid) ||
              ((!existing().keys().hasAny(['userId']) || existing().userId == null) && existing().keys().hasAny(['email']) && isUserEmail(existing().email) && request.auth.token.email_verified == true)
            ) &&
            incoming().userId == request.auth.uid &&
            (!existing().keys().hasAny(['createdAt']) || incoming().createdAt == existing().createdAt) &&
            incoming().updatedAt == request.time &&
            (
              // Non-admins cannot self-approve
              incoming().status == existing().status ||
              (existing().status == 'approved' && incoming().status == 'pending')
            ) &&
            (
              // Non-admins cannot change systemRole to admin
               existing().systemRole == incoming().systemRole ||
              (!existing().keys().hasAny(['systemRole']) && (!incoming().keys().hasAny(['systemRole']) || incoming().systemRole == 'contributor'))
            )
          ) ||
          // Claim profile (if currently unclaimed)
          (
            (!existing().keys().hasAny(['userId']) || existing().userId == null) &&
            incoming().userId == request.auth.uid &&
            (!existing().keys().hasAny(['createdAt']) || incoming().createdAt == existing().createdAt) &&
            incoming().updatedAt == request.time &&
            incoming().status == existing().status &&
            incoming().diff(existing()).affectedKeys().hasOnly(['userId', 'updatedAt'])
          ) ||
          // Action: Flag/Report (allows incrementing flagCount, setting flagged = true, and appending flaggedReasons)
          (
            incoming().diff(existing()).affectedKeys().hasOnly(['flagged', 'flagCount', 'flaggedReasons']) &&
            incoming().flagged == true &&
            (
              incoming().flagCount == 1 ||
              incoming().flagCount == (existing().keys().hasAny(['flagCount']) ? existing().flagCount + 1 : 1)
            )
          )
        )
      );

      allow delete: if isSignedIn() && (
        isAdmin() || existing().userId == request.auth.uid
      );
    }

    // Messages Collection
    match /messages/{messageId} {
      // Single get allowed for admin or recipient
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.contributorUserId == request.auth.uid ||
        (resource.data.keys().hasAny(['contributorEmail']) && isUserEmail(resource.data.contributorEmail))
      );

      // List queries are secure: forced parameter constraints
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.contributorUserId == request.auth.uid ||
        (resource.data.keys().hasAny(['contributorEmail']) && isUserEmail(resource.data.contributorEmail))
      );

      // Creation is open for contact support
      allow create: if isValidId(messageId) && isValidMessage(incoming()) && incoming().createdAt == request.time;

      // Recipient or admin can update 'read' status
      allow update: if isSignedIn() && (
        isAdmin() || (
          (existing().contributorUserId == request.auth.uid || (existing().keys().hasAny(['contributorEmail']) && isUserEmail(existing().contributorEmail))) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['read'])
        )
      );

      allow delete: if isSignedIn() && (
        isAdmin() || 
        existing().contributorUserId == request.auth.uid ||
        (existing().keys().hasAny(['contributorEmail']) && isUserEmail(existing().contributorEmail))
      );
    }

    // Reports Collection
    match /reports/{reportId} {
      allow get: if isSignedIn() && isAdmin();
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isValidId(reportId) &&
                    incoming().contributorId is string &&
                    incoming().contributorName is string &&
                    incoming().reason is string &&
                    incoming().explanation is string &&
                    incoming().reporterEmail is string &&
                    incoming().createdAt == request.time;
      allow delete: if isSignedIn() && isAdmin();
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
